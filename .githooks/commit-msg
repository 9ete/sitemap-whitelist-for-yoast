#!/bin/sh

# ──────────────────────────────────────────────────────────────────────
# commit-msg hook
#
# 1. Validate the commit message against the Conventional Commits spec
#    (with an optional TICKET-NNN: prefix).
# 2. Auto-fix + lint, then run the PHP unit suite. Cypress e2e runs only
#    when a reachable base URL is present (skipped otherwise).
# ──────────────────────────────────────────────────────────────────────

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# ── Step 1: Conventional Commits validation ──────────────────────────
if ! echo "$commit_msg" | grep -qE '^(Merge|fixup!|squash!|amend!|Revert) '; then
	pattern='^([A-Z]+-[0-9]+: )?(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9 _/.-]+\))?!?: .+'
	if ! echo "$commit_msg" | head -1 | grep -qE "$pattern"; then
		echo ""
		echo "ERROR: Commit message does not follow the Conventional Commits specification."
		echo ""
		echo "  Expected: [TICKET-NNN: ]<type>[optional scope]: <description>"
		echo "  Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
		echo ""
		echo "  Examples:"
		echo "    SWY-1: feat(admin): whitelist management settings screen"
		echo "    chore: update composer.lock"
		echo ""
		echo "  Your message: $(head -1 "$commit_msg_file")"
		echo ""
		exit 1
	fi
fi

# ── Step 2: Auto-fix formatting then lint ────────────────────────────
composer lint:fix
composer lint || exit 1

# ── Step 3: PHP unit tests ───────────────────────────────────────────
composer test || exit 1

# ── Step 4: Cypress e2e (skip if unavailable or base URL unreachable) ─
if [ -d "node_modules/.bin" ] && npx cypress --version >/dev/null 2>&1; then
	if curl -sSf "${CYPRESS_BASE_URL:-https://swy.lndo.site}" -o /dev/null 2>/dev/null; then
		if [ -z "${CYPRESS_BROWSER:-}" ]; then
			if [ -f "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" ]; then
				CYPRESS_BROWSER="chrome"
			else
				CYPRESS_BROWSER="electron"
			fi
		fi
		npx cypress run --browser "$CYPRESS_BROWSER" || exit 1
	else
		echo "Skipping Cypress e2e: ${CYPRESS_BASE_URL:-https://swy.lndo.site} not reachable"
	fi
fi
